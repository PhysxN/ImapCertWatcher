<Window x:Class="ImapCertWatcher.MainWindow"
        x:Name="root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Watcher ЭЦП"
        Height="880"
        Width="1300"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid Margin="8" Background="{DynamicResource WindowBackgroundBrush}">
        <TabControl Style="{StaticResource ModernTabControlStyle}"
                    SelectionChanged="TabControl_SelectionChanged">

            <!-- Сертификаты -->
            <TabItem Header="Сертификаты"
                     Style="{StaticResource ModernTabItemStyle}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Панель кнопок -->
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <Button x:Name="btnCheckNewCerts"
                                Content="Новые сертификаты"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnCheckNewCerts_Click"/>

                        <Button x:Name="btnCheckNewRevokes"
                                Content="Новые аннулирования"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnCheckNewRevokes_Click"/>

                        <Button x:Name="btnExportExcel"
                                Content="Экспорт в Excel"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnExportExcel_Click"/>

                        <Button x:Name="btnDeleteSelected"
                                Content="Пометить на удаление"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnDeleteSelected_Click"/>

                        <Button x:Name="btnRestoreSelected"
                                Content="Восстановить"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnRestoreSelected_Click"/>

                        <Button x:Name="btnLoadCer"
                                Content="Загрузить CER"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnLoadCer_Click"
                                ToolTip="Загрузить файл сертификата (*.cer)"/>

                        <TextBlock x:Name="txtServerStatus"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextColorBrush}"
                                   Text="⚪ Сервер: неизвестно"/>
                    </StackPanel>

                    <!-- Панель состояния сервера -->
                    <Border Grid.Row="1"
                            Margin="0,0,0,8"
                            Padding="6"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderColorBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <DockPanel LastChildFill="False">
                            <TextBlock x:Name="txtNextCheck"
                                       DockPanel.Dock="Left"
                                       Margin="0,0,16,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextColorBrush}"
                                       Text="Следующая проверка: --:--"/>

                            <ProgressBar x:Name="pbServerProgress"
                                         DockPanel.Dock="Right"
                                         Width="160"
                                         Height="14"
                                         Visibility="Collapsed"
                                         IsIndeterminate="True"/>
                        </DockPanel>
                    </Border>

                    <!-- Поиск -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <TextBlock Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextColorBrush}"
                                   Text="Поиск по ФИО:"/>

                        <TextBox x:Name="txtSearchFio"
                                 Width="300"
                                 VerticalAlignment="Center"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 TextChanged="TxtSearchFio_TextChanged"
                                 ToolTip="Введите ФИО для поиска"/>

                        <Button x:Name="btnClearSearch"
                                Content="Очистить"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnClearSearch_Click"
                                ToolTip="Очистить поиск"/>
                    </StackPanel>

                    <!-- Фильтры -->
                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <TextBlock Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextColorBrush}"
                                   Text="Фильтр по зданию:"/>

                        <RadioButton x:Name="rbAllBuildings"
                                     Content="Все"
                                     GroupName="BuildingFilter"
                                     Style="{StaticResource ModernRadioButtonStyle}"
                                     IsChecked="True"
                                     Checked="BuildingFilter_Checked"/>

                        <RadioButton x:Name="rbKrasnoflotskaya"
                                     Content="Краснофлотская"
                                     GroupName="BuildingFilter"
                                     Style="{StaticResource ModernRadioButtonStyle}"
                                     Checked="BuildingFilter_Checked"/>

                        <RadioButton x:Name="rbPionerskaya"
                                     Content="Пионерская"
                                     GroupName="BuildingFilter"
                                     Style="{StaticResource ModernRadioButtonStyle}"
                                     Checked="BuildingFilter_Checked"/>

                        <CheckBox x:Name="chkShowDeleted"
                                  Content="Показывать удаленные"
                                  Style="{StaticResource ModernCheckBoxStyle}"
                                  Checked="ChkShowDeleted_Changed"
                                  Unchecked="ChkShowDeleted_Changed"/>
                    </StackPanel>

                    <!-- Таблица -->
                    <DataGrid x:Name="dgCerts"
                              Grid.Row="4"
                              Style="{StaticResource ModernDataGridStyle}"
                              HeadersVisibility="Column"
                              RowDetailsVisibilityMode="Collapsed"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              IsReadOnly="False"
                              SelectionMode="Single"
                              CanUserSortColumns="True"
                              CanUserResizeColumns="True"
                              LoadingRow="DgCerts_LoadingRow"
                              ContextMenuOpening="DgCerts_ContextMenuOpening"
                              CellEditEnding="DgCerts_CellEditEnding"
                              BeginningEdit="DgCerts_BeginningEdit"
                              PreparingCellForEdit="DgCerts_PreparingCellForEdit"
                              Loaded="DgCerts_Loaded">

                        <DataGrid.ContextMenu>
                            <ContextMenu Style="{StaticResource ModernContextMenuStyle}">
                                <MenuItem x:Name="miAddArchive"
                                          Header="Добавить архив с подписью"
                                          Click="AddArchiveMenuItem_Click"/>
                                <Separator/>
                                <MenuItem x:Name="miExportSelected"
                                          Header="Экспорт выделенного"
                                          Click="ExportSelectedMenuItem_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО"
                                                Width="2*"
                                                IsReadOnly="True"
                                                Binding="{Binding Fio, Mode=OneWay}"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>

                            <DataGridTextColumn Header="Сертификат"
                                                Width="*"
                                                IsReadOnly="True"
                                                Binding="{Binding CertNumber, Mode=OneWay}"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>

                            <DataGridTemplateColumn Header="Токен" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TokenSn}"
                       Style="{StaticResource DataGridTextBlockStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>

                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding AvailableTokens}"
                  ItemContainerStyle="{StaticResource DataGridComboBoxItemStyle}"
                  SelectedValue="{Binding TokenId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  SelectedValuePath="Id"
                  DisplayMemberPath="Sn"
                  IsEditable="True"
                  StaysOpenOnEdit="True"
                  IsTextSearchEnabled="False"
                  IsEnabled="{Binding CanEditToken}"
                  Loaded="TokenComboBox_Loaded"
                  GotKeyboardFocus="TokenComboBox_GotKeyboardFocus"
                  DropDownClosed="TokenComboBox_DropDownClosed"
                  SelectionChanged="TokenComboBox_SelectionChanged"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Начало"
                                                Width="*"
                                                IsReadOnly="True"
                                                Binding="{Binding DateStart, Mode=OneWay, StringFormat=dd.MM.yyyy}"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>

                            <DataGridTextColumn Header="Окончание"
                                                Width="*"
                                                IsReadOnly="True"
                                                Binding="{Binding DateEnd, Mode=OneWay, StringFormat=dd.MM.yyyy}"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>

                            <DataGridTextColumn Header="Осталось дней"
                                                Width="*"
                                                IsReadOnly="True"
                                                Binding="{Binding DaysLeft, Mode=OneWay}"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>

                            <DataGridTemplateColumn Header="Архив с ЭЦП" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="📁 Открыть"
                                                Padding="8,2"
                                                FontSize="11"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="BtnOpenArchive_Click"
                                                ToolTip="Распаковать и открыть архив с ЭЦП"
                                                IsEnabled="{Binding HasArchive}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Здание" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Building}"
                       Style="{StaticResource DataGridTextBlockStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>

                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox Style="{StaticResource DataGridComboBoxStyle}"
                      ItemsSource="{Binding AvailableBuildings, RelativeSource={RelativeSource AncestorType=Window}}"
                      SelectedItem="{Binding Building, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      SelectionChanged="BuildingComboBox_SelectionChanged"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Примечание" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DataGridTextBoxStyle}"
                                                 LostFocus="NoteTextBox_LostFocus"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Аннулирован"
                                                Width="*"
                                                IsReadOnly="True"
                                                Binding="{Binding RevokedDisplay}"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>

                            <DataGridCheckBoxColumn Header="Удален"
                                                    Width="*"
                                                    IsReadOnly="True"
                                                    Binding="{Binding IsDeleted}"
                                                    ElementStyle="{StaticResource DataGridCheckBoxStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Статус -->
                    <StatusBar Grid.Row="5"
                               Margin="0,8,0,4"
                               Style="{StaticResource ModernStatusBarStyle}">
                        <StatusBarItem>
                            <TextBlock x:Name="statusText"
                                       Foreground="{DynamicResource TextColorBrush}"
                                       Text="Готов"/>
                        </StatusBarItem>

                        <StatusBarItem>
                            <TextBlock x:Name="searchStatusText"
                                       Margin="20,0,0,0"
                                       Foreground="{DynamicResource TextColorBrush}"/>
                        </StatusBarItem>

                        <StatusBarItem>
                            <ProgressBar x:Name="exportProgress"
                                         Width="100"
                                         Height="16"
                                         Margin="20,0,0,0"
                                         Visibility="Collapsed"/>
                        </StatusBarItem>
                    </StatusBar>

                    <!-- Мини-лог -->
                    <Border Grid.Row="6"
                            Margin="0,4,0,4"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderColorBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <TextBox x:Name="txtMiniLog"
                                 MaxHeight="60"
                                 Margin="4,2"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="10"
                                 Foreground="{DynamicResource TextColorBrush}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Hidden"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 IsHitTestVisible="False"
                                 ToolTip="Последние действия"
                                 Text="Мини-лог готов"/>
                    </Border>

                    <!-- Прогресс -->
                    <ProgressBar x:Name="progressMailCheck"
                                 Grid.Row="7"
                                 Height="6"
                                 Margin="0,4,0,2"
                                 Visibility="Collapsed"
                                 IsIndeterminate="True"
                                 Background="{DynamicResource ControlBackgroundBrush}"
                                 Foreground="{DynamicResource AccentColorBrush}"/>
                </Grid>
            </TabItem>

            <!-- Токены -->
            <TabItem Header="Токены"
                     Style="{StaticResource ModernTabItemStyle}"
                     DataContext="{Binding TokensVm, RelativeSource={RelativeSource AncestorType=Window}}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Панель -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Добавить токен"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Click="BtnAddToken_Click"/>

                            <CheckBox Content="Показать занятые"
                                      Margin="15,0,0,0"
                                      VerticalAlignment="Center"
                                      Style="{StaticResource ModernCheckBoxStyle}"
                                      IsChecked="{Binding ShowBusyTokens, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Margin="4,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextColorBrush}"
                                       Text="Поиск:"/>

                            <TextBox Width="320"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Поиск по номеру токена и ФИО"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Карточки токенов -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Margin="6,12,0,6"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AccentColorBrush}"
                                       Text="Свободные"/>

                            <ItemsControl ItemsSource="{Binding FreeTokens}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="220"
                                                Margin="6"
                                                Padding="10"
                                                Background="{DynamicResource FreeTokenBrush}"
                                                CornerRadius="10"
                                                Cursor="Hand"
                                                Style="{StaticResource TokenCardHoverStyle}">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextColorBrush}"
                                                           Text="{Binding Sn}"/>

                                                <Button Content="Удалить"
                                                        Margin="0,6,0,0"
                                                        Padding="6,2"
                                                        FontSize="11"
                                                        Tag="{Binding}"
                                                        Style="{StaticResource ModernButtonStyle}"
                                                        Click="BtnDeleteToken_Click"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Margin="6,12,0,6"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AccentColorBrush}"
                                       Text="Занятые"
                                       Visibility="{Binding ShowBusyTokens, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <ItemsControl ItemsSource="{Binding BusyTokens}"
                                          Visibility="{Binding ShowBusyTokens, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="220"
                                                Margin="6"
                                                Padding="10"
                                                Background="{DynamicResource BusyTokenBrush}"
                                                CornerRadius="10"
                                                Cursor="Hand"
                                                Style="{StaticResource TokenCardHoverStyle}">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextColorBrush}"
                                                           Text="{Binding Sn}"/>

                                                <TextBlock FontSize="12"
                                                           Opacity="0.85"
                                                           Foreground="{DynamicResource TextColorBrush}"
                                                           Text="{Binding OwnerFioFormatted}"/>

                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Button Grid.Column="0"
                                                            Content="Освободить"
                                                            Margin="0,0,3,0"
                                                            Padding="6,2"
                                                            FontSize="11"
                                                            Tag="{Binding}"
                                                            Style="{StaticResource ModernButtonStyle}"
                                                            Click="BtnUnassignToken_Click"/>

                                                    <Button Grid.Column="1"
                                                            Content="Удалить"
                                                            Margin="3,0,0,0"
                                                            Padding="6,2"
                                                            FontSize="11"
                                                            Tag="{Binding}"
                                                            Style="{StaticResource ModernButtonStyle}"
                                                            Click="BtnDeleteToken_Click"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Статус -->
                    <StatusBar Grid.Row="2"
                               Margin="0,8,0,4"
                               Style="{StaticResource ModernStatusBarStyle}">
                        <StatusBarItem>
                            <TextBlock x:Name="tokensStatusText"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextColorBrush}"
                                       Text="Токены загружены"/>
                        </StatusBarItem>
                    </StatusBar>
                </Grid>
            </TabItem>

            <!-- Настройки -->
            <TabItem Header="Настройки"
                     Style="{StaticResource ModernTabItemStyle}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Левая колонка -->
                            <StackPanel Grid.Column="0">
                                <GroupBox Header="Подключение к серверу"
                                          Margin="0,0,0,12"
                                          Style="{StaticResource ModernGroupBoxStyle}">
                                    <StackPanel Margin="8">
                                        <TextBlock Foreground="{DynamicResource TextColorBrush}"
                                                   Text="IP сервера:"/>

                                        <TextBox Height="26"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Text="{Binding ServerIp}"
                                                 ToolTip="IP компьютера где запущен сервер"/>

                                        <TextBlock Margin="0,8,0,2"
                                                   Foreground="{DynamicResource TextColorBrush}"
                                                   Text="Порт:"/>

                                        <TextBox Height="26"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Text="{Binding ServerPort}"/>

                                        <Button Content="Сохранить настройки"
                                                Margin="0,12,0,0"
                                                Height="30"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="BtnSaveSettings_Click"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>

                            <!-- Разделитель -->
                            <Rectangle Grid.Column="1"
                                       Width="1"
                                       Margin="0,6"
                                       VerticalAlignment="Stretch"
                                       Fill="{DynamicResource BorderColorBrush}"/>

                            <!-- Правая колонка -->
                            <StackPanel Grid.Column="2">
                                <GroupBox Header="Обслуживание"
                                          Margin="0,0,0,12"
                                          Style="{StaticResource ModernGroupBoxStyle}">
                                    <StackPanel Margin="8">
                                        <Button Content="Перечитать все сертификаты"
                                                Margin="0,0,0,8"
                                                Height="30"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="BtnFullRecheckCerts_Click"
                                                ToolTip="Полный обход всей папки новых сертификатов"/>

                                        <Button Content="Перечитать все аннулирования"
                                                Margin="0,0,0,8"
                                                Height="30"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="BtnFullRecheckRevokes_Click"
                                                ToolTip="Полный обход всей папки аннулирований"/>

                                        <Button Content="⚠ Сбросить аннулирования"
                                                Margin="0,10,0,0"
                                                Height="30"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="BtnResetRevokes_Click"
                                                ToolTip="Удаляет отметки аннулирования и историю REVOKE"/>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="Интерфейс"
                                          Style="{StaticResource ModernGroupBoxStyle}">
                                    <StackPanel Margin="8">
                                        <CheckBox x:Name="chkDarkTheme"
                                                  Content="Темная тема"
                                                  Style="{StaticResource ModernCheckBoxStyle}"
                                                  Checked="ChkDarkTheme_Changed"
                                                  Unchecked="ChkDarkTheme_Changed"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <!-- Мини-лог -->
                    <Border Grid.Row="1"
                            Margin="0,12,0,4"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderColorBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <TextBlock x:Name="txtMiniLogSettings"
                                   Margin="4,2"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextColorBrush}"
                                   TextWrapping="NoWrap"
                                   ToolTip="Последние действия"
                                   Text="Мини-лог готов"/>
                    </Border>

                    <!-- Прогресс -->
                    <ProgressBar x:Name="progressMailCheckSettings"
                                 Grid.Row="2"
                                 Height="6"
                                 Margin="0,4,0,2"
                                 Visibility="Collapsed"
                                 IsIndeterminate="True"
                                 Background="{DynamicResource ControlBackgroundBrush}"
                                 Foreground="{DynamicResource AccentColorBrush}"/>
                </Grid>
            </TabItem>

            <!-- Логи -->
            <TabItem Header="Логи"
                     Style="{StaticResource ModernTabItemStyle}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <Button x:Name="btnRefreshLogs"
                                Content="Обновить логи"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnRefreshLogs_Click"/>

                        <Button x:Name="btnClearLogs"
                                Content="Очистить старые логи"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnClearLogs_Click"/>

                        <Button x:Name="btnOpenLogFolder"
                                Content="Открыть папку логов"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnOpenLogFolder_Click"/>
                    </StackPanel>

                    <TextBox x:Name="txtLogs"
                             Grid.Row="1"
                             Style="{StaticResource ModernTextBoxStyle}"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="10"
                             TextWrapping="Wrap"/>

                    <StatusBar Grid.Row="2"
                               Margin="0,8,0,0"
                               Style="{StaticResource ModernStatusBarStyle}">
                        <StatusBarItem>
                            <TextBlock x:Name="logStatusText"
                                       Foreground="{DynamicResource TextColorBrush}"
                                       Text="Логи загружены"/>
                        </StatusBarItem>
                    </StatusBar>

                    <ProgressBar x:Name="progressMailCheckLogs"
                                 Grid.Row="3"
                                 Height="6"
                                 Margin="0,4,0,2"
                                 Visibility="Collapsed"
                                 IsIndeterminate="True"
                                 Background="{DynamicResource ControlBackgroundBrush}"
                                 Foreground="{DynamicResource AccentColorBrush}"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>